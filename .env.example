HIKVISION_IP=192.168.1.64
HIKVISION_USERNAME=admin
HIKVISION_PASSWORD=your_password_here

# Usually 554 for RTSP.
HIKVISION_RTSP_PORT=554

# Hikvision main stream is usually 101, sub stream is usually 102.
HIKVISION_CHANNEL=101

# Optional: set this if your camera needs a custom full URL.
# Example:
# HIKVISION_RTSP_URL=rtsp://admin:password@192.168.1.64:554/Streaming/Channels/101
HIKVISION_RTSP_URL=

# Draw boxes around moving objects/areas.
ENABLE_MOTION_TRACKING=true
MIN_MOTION_AREA=900

# Display window size. This does not change camera recording/stream quality.
WINDOW_WIDTH=1980
WINDOW_HEIGHT=1200
